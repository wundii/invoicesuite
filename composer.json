{
    "name": "horstoeko/invoicesuite",
    "keywords": [],
    "description": "A library",
    "homepage": "https://github.com/horstoeko/invoicesuite",
    "type": "package",
    "license": "MIT",
    "prefer-stable": true,
    "authors": [
        {
            "name": "HorstOeko",
            "email": "horstoeko@erling.com.de",
            "role": "lead"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "horstoeko\\invoicesuite\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "horstoeko\\invoicesuite\\tests\\": "tests"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-simplexml": "*",
        "doctrine/annotations": "^2.0",
        "goetas-webservices/xsd2php-runtime": "^0.2.17",
        "horstoeko/mimedb": "^1.0",
        "horstoeko/stringmanagement": "^1",
        "jms/serializer": "^3",
        "setasign/fpdf": "^1",
        "setasign/fpdi": "^2",
        "smalot/pdfparser": "^0|^2"
    },
    "require-dev": {
        "goetas-webservices/xsd2php": "^0",
        "nette/php-generator": "*",
        "nikic/php-parser": "^5.4",
        "pdepend/pdepend": "^2",
        "phpdocumentor/reflection-docblock": "^5",
        "phpmd/phpmd": "@stable",
        "phpstan/phpstan": "^1|^2",
        "phpunit/phpunit": "^9",
        "rector/rector": "*",
        "squizlabs/php_codesniffer": "^3"
    },
    "scripts": {
        "post-autoload-dump": [
            "horstoeko\\invoicesuite\\utils\\InvoiceSuiteClassFinder::clearCache"
        ],
        "tests": "./vendor/bin/phpunit ./tests/",
        "testsreal": "./vendor/bin/phpunit --configuration ./build/phpunit.xml",
        "testsrealquick": "./vendor/bin/phpunit --configuration ./build/phpunitquick.xml",
        "phpcs": "@phpcs12",
        "phpcs12": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpcs --standard=./build/phpcsrules_psr12.xml --extensions=php --ignore=autoload.php ./src ./tests"
        ],
        "phpcbf": "@phpcbf12",
        "phpcbf12": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpcbf --standard=./build/phpcsrules_psr12.xml -q ./src ./tests"
        ],
        "phpstan": "@phpstan12",
        "phpstan12": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpstan analyze -c ./build/phpstan.neon --autoload-file=vendor/autoload.php --no-interaction --no-progress"
        ],
        "phpmd": "@phpmd12",
        "phpmd12": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpmd src xml ./build/phpmd.xml"
        ],
        "checkstyle": [
            "Composer\\Config::disableProcessTimeout",
            "@phpmd",
            "@phpcs",
            "@phpstan"
        ],
        "rector": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/rector --config=./build/phprectorconfig.php --clear-cache"
        ]
    }
}
