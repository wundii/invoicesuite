includes:
    - phar://phpstan.phar/conf/bleedingEdge.neon
parameters:
    paths:
        - ../src
    level: 6
    treatPhpDocTypesAsCertain: false
    phpVersion: 80400
    parallel:
        jobSize: 20
        maximumNumberOfProcesses: 32
        minimumNumberOfJobsPerProcess: 2
    ignoreErrors:
        -
            identifier: classConstant.internalClass
